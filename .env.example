# Copy to .env.local and fill in real values. Do NOT commit .env.local.
# SMTP for the Book-a-demo form. For Gmail, SMTP_PASS must be an App Password
# (Google Account → Security → 2-Step Verification → App passwords), not your
# normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASS=your-app-password

# Inbox that receives demo requests (defaults to SMTP_USER if omitted).
DEMO_INBOX=you@example.com

# Optional: Google Search Console HTML tag value.
GOOGLE_SITE_VERIFICATION=your-google-site-verification-token
